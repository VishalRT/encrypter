---
# --- DOCUMENTATION ---
# NL.8, NL.9, NL.10, NL.17: readability-identifier-naming.*
# SF.8: modernize-pragma-once
# SF.1-SF.3: readability-inconsistent-declaration-parameter-name
# C.12: cppcoreguidelines-avoid-const-or-ref-data-members
# SL.con.1: cppcoreguidelines-avoid-c-arrays
# Enum.3: cppcoreguidelines-use-enum-class
# C.164: google-explicit-constructor
# ES.46: readability-implicit-bool-conversion
# ES.46: bugprone-implicit-widening-of-multiplication-result
# I.11, C.33, R.3: cppcoreguidelines-owning-memory
# R.10: cppcoreguidelines-no-malloc
# R.11: modernize-use-unique-ptr
# ES.11: modernize-use-auto
# C.80: modernize-use-equals-default
# C.81: modernize-use-equals-delete
# C.128: modernize-use-override
# ES.56: performance-move-const-arg
# P.9: performance-unnecessary-copy-initialization
# F.16: performance-unnecessary-value-param

Checks: >
  -*,
  readability-identifier-naming,
  modernize-pragma-once,
  readability-inconsistent-declaration-parameter-name,
  cppcoreguidelines-avoid-const-or-ref-data-members,
  cppcoreguidelines-avoid-c-arrays,
  cppcoreguidelines-use-enum-class,
  google-explicit-constructor,
  readability-implicit-bool-conversion,
  bugprone-implicit-widening-of-multiplication-result,
  cppcoreguidelines-owning-memory,
  cppcoreguidelines-no-malloc,
  modernize-use-unique-ptr,
  modernize-use-auto,
  modernize-use-equals-default,
  modernize-use-equals-delete,
  modernize-use-override,
  performance-move-const-arg,
  performance-unnecessary-copy-initialization,
  performance-unnecessary-value-param

CheckOptions:
    # NL.8: Use all-uppercase names for macro-like entities
    - key: readability-identifier-naming.ConstantCase
      value: UPPER_CASE
    - key: readability-identifier-naming.MacroDefinitionCase
      value: UPPER_CASE

    # NL.9: Prefer PascalCase for type names
    - key: readability-identifier-naming.ClassCase
      value: CamelCase
    - key: readability-identifier-naming.StructCase
      value: CamelCase
    - key: readability-identifier-naming.EnumCase
      value: CamelCase
    - key: readability-identifier-naming.TypeAliasCase
      value: CamelCase
    - key: readability-identifier-naming.TemplateParameterCase
      value: CamelCase
    - key: readability-identifier-naming.ConceptCase
      value: CamelCase

    # Enum.5: Don't use ALL_CAPS for enumerators
    - key: readability-identifier-naming.EnumConstantCase
      value: CamelCase

    # NL.10: Use snake_case for functions, variables, and scopes
    - key: readability-identifier-naming.NamespaceCase
      value: lower_case
    - key: readability-identifier-naming.FunctionCase
      value: lower_case
    - key: readability-identifier-naming.VariableCase
      value: lower_case
    - key: readability-identifier-naming.ParameterCase
      value: lower_case
    - key: readability-identifier-naming.MemberCase
      value: lower_case

    # NL.17: Use '_' as suffix for private members
    - key: readability-identifier-naming.PrivateMemberSuffix
      value: '_'

    # SF.8: Use #pragma once instead of header guards
    - key: modernize-pragma-once.FixHeaderGuards
      value: 'true'
